<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/divisionControlsRoot">


    <SeekBar
        android:id="@+id/divisionVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="30"
        android:min="-30"
        android:minHeight="50dp"
        android:minWidth="200dp"
        />

    <LinearLayout
        android:id="@+id/buttons_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <LinearLayout
            android:id="@+id/tremulant_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >


        </LinearLayout>
        <LinearLayout
            android:id="@+id/on_off_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
           >
            <Button
                android:id="@+id/all_division_stops_on"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/division_on" />
            <Button
                android:id="@+id/all_division_stops_off"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/division_off" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>